            "header": [{ "key": "Authorization", "value": "Bearer {{advisorToken}}" }],
            "url": "{{baseUrl}}/api/goals/client/1"
          }
        },
        {
          "name": "ADVISOR: Create recommendation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{advisorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"clientId\":  1,\n  \"modelId\":   1,\n  \"rationale\": \"Balanced tilt recommended post Q1 review\"\n}" },
            "url": "{{baseUrl}}/api/recommendations"
          }
        }
      ]
    },
    {
      "name": "Act 12 — Spoofing defense (all should be ignored)",
      "item": [
        {
          "name": "Client token + spoofed X-Auth headers — still 403",
          "description": "Attacker sends spoofed X-Auth-Client-Id=4 and X-Auth-Roles=ROLE_ADMIN. The Gateway filter strips them before the token-derived values are injected. Downstream should see clientId=1/ROLE_CLIENT and reject access to client #4.",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('403 (headers stripped)', () => pm.response.to.have.status(403));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization",    "value": "Bearer {{clientToken}}" },
              { "key": "X-Auth-Client-Id", "value": "4" },
              { "key": "X-Auth-Roles",     "value": "ROLE_ADMIN" }
            ],
            "url": "{{baseUrl}}/api/clients/4"
          }
        }
      ]
    },
    {
      "name": "Act 13 — Unauthenticated & public",
      "item": [
        {
          "name": "NEGATIVE: No token on protected path",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('401', () => pm.expect([401,403]).to.include(pm.response.code));"], "type": "text/javascript" } }
          ],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/accounts/1" }
        },
        {
          "name": "Public: actuator (permitAll)",
          "request": { "method": "GET", "url": "{{baseUrl}}/actuator/health" }
        },
        {
          "name": "Public: fallback",
          "request": { "method": "GET", "url": "{{baseUrl}}/fallback/wealthpro" }
        }
      ]
    }
  ]
}
